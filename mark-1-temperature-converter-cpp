#include <iostream>
using namespace std;
int main() {
    double T;
    int option;
cout << "Write your temperature (Celsius or Fahrenheit) here: ";
cin >> T;
cout << "------------------------------------------" << endl;
cout << "Please select your desired temperature unit: " << endl;
cout << "------------------------------------------" << endl;
cout << "1. Celsius to Fahrenheit " << endl;
cout << "2. Fahrenheit to Celsius " << endl;
cout << "------------------------------------------" << endl;
cin >> option;
if (option == 1){
    cout << "The temperature in Celsius is: " << (T * 1.8) + 32 << endl; //Fahrenheit to Celsius conversion formula.
} else if (option == 2){
    cout << "The temperature in Fahrenheit is: " << (T - 32) / 1.8 << endl; //Celsius to Fahrenheit conversion formula.
} else {
    cout << "Please select a valid option, and try again." << endl;
}

return 0;

}

